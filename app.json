{
  "expo": {
    "name": "ColorApp",
    "slug": "ColorApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "colorapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.PixelcolorPaint.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSExceptionDomains": {
            "3.145.90.196": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": true
            }
          },
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        },
        "NSLocalNetworkUsageDescription": "This app needs access to local network to connect to the development server.",
        "NSPhotoLibraryUsageDescription": "ColorApp saves your finished drawings to your photo library.",
        "NSPhotoLibraryAddUsageDescription": "ColorApp saves your finished drawings to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true,
      "package": "com.PixelcolorPaint.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "imageToSvgApiBaseUrl": "http://3.145.90.196:8000",
      "eas": {
        "projectId": "6adefd7c-76d3-47d6-9859-6c362ead9b56"
      }
    },
    "owner": "piyushexpo",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/6adefd7c-76d3-47d6-9859-6c362ead9b56"
    }
  }
}